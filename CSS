/* 3D-kub stil */
.cube-container {
    width: 300px;
    height: 300px;
    margin: 20px auto;
    border: 2px solid var(--accent-color);
}

/* Notationer och kontrollpanel */
.notation-display {
    text-align: center;
    font-family: monospace;
    margin-top: 10px;
}

.control-panel {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-top: 10px;
}

/* Chatbot stil */
#chat-container {
    position: fixed;
    bottom: 20px;
    right: 20px;
    width: 300px;
    height: 400px;
    background-color: var(--card-bg);
    border: 2px solid var(--accent-color);
    border-radius: 10px;
    display: flex;
    flex-direction: column;
}

#chat-header {
    background-color: var(--accent-color);
    color: white;
    padding: 10px;
    text-align: center;
    font-weight: bold;
    border-top-left-radius: 8px;
    border-top-right-radius: 8px;
}

#chat-messages {
    flex-grow: 1;
    overflow-y: auto;
    padding: 10px;
}

#chat-input {
    border: none;
    padding: 10px;
    border-bottom-left-radius: 8px;
}

#chat-submit {
    border: none;
    background-color: var(--accent-color);
    color: white;
    padding: 10px;
    border-bottom-right-radius: 8px;
    cursor: pointer;
}
